msgid "Category name #1"
msgstr "카테고리 이름 #1"

#: indico/modules/categories/forms.py
msgid "Selected events will be moved into a new sub-category with this title."
msgstr "선택한 행사는 이 제목의 새 하위 카테고리로 이동합니다."

#: indico/modules/categories/forms.py
